// gdFinance — KPO knjiga za paušalne firme
// Novac se čuva kao CEO BROJ u parama (1 RSD = 100 para) radi prenosivosti i tačnosti.
// redniBroj i kumulativ se NE skladište — računaju se pri čitanju (sort po datumNaplate).
//
// BAZA: Neon Postgres. DATABASE_URL = pooled string (aplikacija),
// DIRECT_URL = direktan string (samo za `prisma db push` / migracije).
// LOKALNI RAZVOJ: Neon dev branch — stringovi dev brancha idu u lokalni .env.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  password  String
  companies Company[]
  createdAt DateTime  @default(now())
}

model Company {
  id              String     @id @default(cuid())
  userId          String
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  naziv           String
  pib             String?
  maticniBroj     String?
  adresa          String?
  sifraDelatnosti String?
  pausalLimit     Int        @default(600000000) // 6.000.000 RSD u parama (prag gubitka paušala)
  isSefEnabled    Boolean    @default(false)
  racun           String? // tekući račun, npr. "160-6000001236873-68"
  telefon         String?
  email           String?
  mesto           String? // mesto fakturisanja/prometa na fakturi
  clients         Client[]
  kpoEntries      KpoEntry[]
  debts           Debt[]
  fakture         Faktura[]
  createdAt       DateTime   @default(now())

  @@index([userId])
}

model Client {
  id          String     @id @default(cuid())
  companyId   String
  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  naziv       String
  pib         String?
  maticniBroj String?
  adresa      String?
  mesto       String?
  kpoEntries  KpoEntry[]
  fakture     Faktura[]
  createdAt   DateTime   @default(now())

  @@index([companyId])
}

model KpoEntry {
  id              String   @id @default(cuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  godina          Int
  datumNaplate    DateTime
  brojIsprave     String?
  opis            String?
  clientId        String?
  client          Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  prihodProizvodi Int      @default(0) // para
  prihodUsluge    Int      @default(0) // para
  // Upis nastao iz fakture — brisanje fakture briše i ovaj upis (kaskada na nivou baze).
  fakturaId       String?  @unique
  faktura         Faktura? @relation(fields: [fakturaId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([companyId, godina, datumNaplate])
  @@index([clientId])
}

model Faktura {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  broj      Int // numerički deo; 52 -> prikaz "052/2026"
  godina    Int // uvek izvedeno iz datum.getFullYear()
  datum     DateTime // datum fakturisanja = datum prometa dobara
  valuta    DateTime // rok plaćanja (podrazumevano datum + 7 dana)

  // Snapshot kupca u trenutku izdavanja — kasnija izmena klijenta ne menja stare fakture.
  kupacNaziv       String
  kupacAdresa      String?
  kupacMesto       String?
  kupacPib         String?
  kupacMaticniBroj String?
  clientId         String?
  client           Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  ukupno    Int // para — zbir stavki
  stavke    FakturaStavka[]
  kpoEntry  KpoEntry?
  createdAt DateTime        @default(now())

  @@unique([companyId, godina, broj])
  @@index([companyId, godina])
}

model FakturaStavka {
  id           String  @id @default(cuid())
  fakturaId    String
  faktura      Faktura @relation(fields: [fakturaId], references: [id], onDelete: Cascade)
  redosled     Int
  naziv        String
  jedinicaMere String  @default("kom")
  kolicina     Int // u stotinkama (6000 = 60,00) — ista konvencija kao para
  cena         Int // para po jedinici
  ukupno       Int // para = Math.round(kolicina * cena / 100)

  @@index([fakturaId])
}

model Debt {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  klijent   String
  iznos     Int // para (dug klijenta)
  createdAt DateTime @default(now())

  @@index([companyId])
}
